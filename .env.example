# Mobile.de Scraper Configuration
# Copy this file to .env and adjust values

# Target state (lowercase, hyphenated)
STATE=nordrhein-westfalen

# Scraping limits
MAX_VENDORS=0
MAX_CARS_PER_VENDOR=0
MAX_PAGES_PER_STATE=0
SKIP_VEHICLE_DETAILS=false
TRAVERSE_VEHICLE_CATEGORIES=true
MAX_DETAIL_FAILURES=2

# Browser
HEADLESS=false
FALLBACK_TO_HEADED_ON_BLOCK=true

# Delays (seconds)
MIN_DELAY=2.0
MAX_DELAY=5.0

# Resume from checkpoint
RESUME=true
CLEAR_CHECKPOINTS=false
